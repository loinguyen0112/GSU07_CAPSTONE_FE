<mvc:View controllerName="hrrequest.hrm.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <f:DynamicPage id="dynamicPageId" toggleHeaderOnTitleClick="false">
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="HR Lifecycle Requests"/>
                </f:heading>
                <f:actions>
                    <Button text="Create New Request" type="Emphasized" press=".onCreateRequest"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader pinnable="true">
                <HBox wrap="Wrap" fitContainer="true" alignItems="Center" class="sapUiSmallMarginBottom">
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="Search Employee" />
                        <SearchField id="searchField" width="15rem" placeholder="Name or ID..." search=".onSearch"/>
                    </VBox>
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="Status" />
                        <ComboBox id="statusFilter" width="10rem" selectionChange=".onFilterChange">
                            <core:Item key="" text="All" />
                            <core:Item key="01" text="Draft" />
                            <core:Item key="02" text="Submitted" />
                            <core:Item key="03" text="Approved" />
                            <core:Item key="04" text="Rejected" />
                        </ComboBox>
                    </VBox>
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="Department" />
                        <ComboBox id="departmentFilter" width="13rem" placeholder="All departments"
                            selectionChange=".onFilterChange" change=".onFilterChange"
                            items="{filters>/departments}">
                            <core:Item key="{filters>DepartmentID}" text="{filters>DepartmentID}" additionalText="{filters>DepartmentName}" />
                        </ComboBox>
                    </VBox>
                    <VBox class="sapUiTinyMarginEnd">
                        <Label text="Requested Role" />
                        <ComboBox id="roleFilter" width="16rem" placeholder="All roles"
                            selectionChange=".onFilterChange" change=".onFilterChange"
                            items="{filters>/roles}">
                            <core:Item key="{filters>RoleName}" text="{filters>RoleName}" additionalText="{filters>Description}" />
                        </ComboBox>
                    </VBox>
                </HBox>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <Table id="requestTable"
                items="{
                    path: '/Request',
                    parameters: {
                        $count: true
                    }
                }"
                mode="SingleSelectMaster"
                selectionChange=".onItemSelect"
                growing="true"
                growingScrollToLoad="true">
                <columns>
                    <Column>
                        <Text text="Employee" />
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="Department" />
                    </Column>
                    <Column minScreenWidth="Desktop" demandPopin="true">
                        <Text text="Email" />
                    </Column>
                    <Column hAlign="End">
                        <Text text="Status" />
                    </Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation">
                        <cells>
                            <ObjectIdentifier title="{TargetUser}" text="{FirstName} {LastName}" />
                            <Text text="{Department}" />
                            <Text text="{Email}" />
                            <ObjectStatus text="{StatusText}" state="{= ${Status} === '01' ? 'Information' : (${Status} === '02' ? 'Warning' : (${Status} === '03' ? 'Success' : (${Status} === '04' ? 'Error' : 'None'))) }" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
    </f:DynamicPage>
</mvc:View>
